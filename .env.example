# =============================================================
# 환경 변수 템플릿 — 실제 값은 .env(로컬) / Vercel Environment Variables(배포)에 설정
# LLM API 키는 더 이상 여기에 저장하지 않는다 (사용자별 암호화 DB 저장으로 이관됨).
# =============================================================

# Supabase (필수)
SUPABASE_URL=https://pqzcviurfjzsgkmaprqe.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<Supabase 대시보드 → Settings → API → service_role 키>

# API 키 암호화 / 세션 토큰 마스터 키 (필수)
# 생성: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<Fernet 마스터 키>

# 로그인 세션 토큰 유효기간(초) — 기본 43200 (12시간)
# AUTH_TOKEN_TTL_SECONDS=43200

# 네이버 책 검색 OpenAPI (선택 — 저자 자동 확정용, 서버 공용 키)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=
